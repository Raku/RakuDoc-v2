=cell When rendering, format all citation lists using the CSL style format specified by the name or by the URL
=row
=cell C<=document>
=cell C«:citation-locale<R<tag>>»
=cell When rendering, format all citation lists using the CSL locale conventions selected by the specified S<IETF BCP 47> language tag
=end table2
=end section

