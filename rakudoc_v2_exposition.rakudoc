	=cell enumeration value in Chinese numerals I<(if supported)>
	=cell C«%z» or C«%小»
=row
	=cell C«%%»
	=cell a literal C«%» I<(only required if literal C«%» is followed by a letter)>
	=cell
=row
	=cell C«%:»
	=cell a literal C«:» I<(only required if literal C«:» is followed by a letter)>
	=cell
	=cell
=end table2

=begin section
=config C :allow<R>
=begin table2 :caption<Options for form fields> :toc
=row :header
	=cell Field option
	=cell Meaning
=row
	=cell C«:ord»
	=cell use ordinal instead of cardinal number I<(if available in requested language)>
=row
	=cell C«:lc»
	=cell use lowercase or informal notation I<(if any)>
=row
	=cell C«:uc»
	=cell use uppercase or formal notation I<(if any)>
=row
	=cell C«:tc»
	=cell use titlecase I<(uppercase first character only)>
=row
	=cell C«:tclc»
	=cell use titlecase for first character, lowercase for the rest
=row
	=cell C«:sc»
	=cell use titlecase for first character of each sentence, preserve ALLCAPS words, lowercase for the rest
=row
	=cell C«:pc»
	=cell use titlecase for first character of each word, preserve ALLCAPS words, lowercase for the rest
=row
	=cell C«:lang<R<xx>>»
	=cell use numbering and/or ordinal system for ISO 639-1 language R<xx> I<(if supported)>
	=cell
=end table2
=end section

=begin section
=config C :allow<R>
=begin table2 :caption«Options related to citations» :toc
=row :header
=cell Block or directive
=cell Option
=cell Meaning
=row
=cell C<=citation>
=cell C«:load<R<URL>>»
=cell Import citation data from the specified URL
=row
=cell C<=citation>
=cell C«:category<R<CatName(s)>>»
=cell Include the block’s citation data in the specified category or categories
=row
=cell C<=document>
